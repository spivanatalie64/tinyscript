;;; tinyscript evaluator in GNU Guile
;;; Walks the AST and interprets Tinyscript code

(define-module (tinyscript eval)
  #:use-module (ice-9 match)
  #:use-module (ice-9 rdelim)
  #:use-module (srfi srfi-1)
  #:use-module (tinyscript parser)
  #:use-module (tinyscript env)
  #:use-module (tinyscript runtime)
  #:export (evaluate evaluate-string evaluate-file))

;; --- Value constructors ---
(define (make-ts-value type val)
  (vector type val))

(define (ts-type v) (vector-ref v 0))
(define (ts-val v) (vector-ref v 1))

(define ts-null (make-ts-value 'null #f))
(define (ts-number n)  (make-ts-value 'number n))
(define (ts-string s)  (make-ts-value 'string s))
(define (ts-boolean b) (make-ts-value 'boolean b))
(define (ts-array a)   (make-ts-value 'array (list->vector a)))
(define (ts-object o)  (make-ts-value 'object o))
(define (ts-fun fn)    (make-ts-value 'function fn))
(define (ts-native fn) (make-ts-value 'native fn))

(define (ts-is-truthy? v)
  (not (or (and (eq? (ts-type v) 'boolean) (not (ts-val v)))
           (and (eq? (ts-type v) 'null) #t)
           (and (eq? (ts-type v) 'number) (zero? (ts-val v)))
           (and (eq? (ts-type v) 'string) (string-null? (ts-val v))))))

;; Current environment parameter (for closures)
(define %current-env (make-parameter #f))

;; --- Evaluation ---

(define (evaluate-prog ast env)
  (let ((stmts (cdr ast)))
    (let loop ((stmts stmts) (result ts-null))
      (if (null? stmts)
          result
          (loop (cdr stmts) (eval-stmt (car stmts) env))))))

(define (eval-stmt stmt env)
  (catch 'tinyscript-return
    (lambda ()
      (eval-stmt/inner stmt env))
    (lambda (key val) val)))

(define (eval-stmt/inner stmt env)
  (match stmt
    (('let name init)
     (let ((val (if init (eval-expr init env) ts-null)))
       (env-define! env name val)
       ts-null))
    (('assign name val)
     (let ((value (eval-expr val env)))
       (cond
        ((string? name) (env-set! env name value))
        ((and (pair? name) (eq? (car name) 'var))
         (env-set! env (cadr name) value))
        (else (error "Invalid assignment target")))
       ts-null))
    (('assign ('index obj key) val)
     (let ((o (eval-expr obj env))
           (k (eval-expr key env))
           (value (eval-expr val env)))
       (vector-set! (ts-val o) (ts-val k) value)
       ts-null))
    (('assign ('member obj key) val)
     (let ((o (eval-expr obj env))
           (value (eval-expr val env)))
       (let ((alist (ts-val o)))
         (let ((existing (assoc key alist)))
           (if existing
               (set-cdr! existing value)
               (error "Cannot assign to member: " key)))
         ts-null)))
    (('if cond then . else-tail)
     (let ((cval (eval-expr cond env)))
       (if (ts-is-truthy? cval)
           (eval-stmt/inner then env)
           (if (pair? else-tail)
               (eval-stmt/inner (car else-tail) env)
               ts-null))))
    (('while cond body)
     (let loop ((result ts-null))
       (if (ts-is-truthy? (eval-expr cond env))
           (begin (eval-stmt/inner body env) (loop result))
           result)))
    (('for init cond step body)
     (eval-stmt/inner init env)
     (let loop ((result ts-null))
       (if (ts-is-truthy? (eval-expr cond env))
           (begin
             (eval-stmt/inner body env)
             (eval-expr step env)
             (loop result))
           result)))
    (('for-in var iterable body)
     (let ((iter (eval-expr iterable env)))
       (let ((arr (ts-val iter)))
         (let loop ((i 0) (result ts-null))
           (if (< i (vector-length arr))
               (begin
                 (env-define! env var (vector-ref arr i))
                 (eval-stmt/inner body env)
                 (loop (1+ i) result))
               result)))))
    (('return val)
     (let ((v (if val (eval-expr val env) ts-null)))
       (throw 'tinyscript-return v)))
    (('block . stmts)
     (let ((block-env (make-env env)))
       (let loop ((stmts stmts) (result ts-null))
         (if (null? stmts)
             result
             (loop (cdr stmts) (eval-stmt (car stmts) block-env))))))
    (('import path)
     (let ((p (ts-val (eval-expr path env))))
       (let ((ast (parse-file p)))
         (evaluate-prog ast (make-env env)))))
    (('export val)
     (eval-expr val env))
    ;; Expression statement
    (default (eval-expr stmt env))))

(define (eval-expr expr env)
  (match expr
    (('literal val)
     (cond
      ((number? val) (ts-number val))
      ((string? val) (ts-string val))
      ((boolean? val) (ts-boolean val))
      ((eq? val 'null) ts-null)
      (default (ts-string (format #f "~a" val)))))
    (('var name)
     (env-lookup env name))
    (('binary op left right)
     (let ((l (eval-expr left env))
           (r (eval-expr right env)))
       (eval-binary op l r)))
    (('unary op val)
     (let ((v (eval-expr val env)))
       (eval-unary op v)))
    (('call callee args)
     (let ((fn (eval-expr callee env))
           (arg-vals (map (lambda (a) (eval-expr a env)) args)))
       (eval-call fn arg-vals env)))
    (('fun #f params body)
     (let ((closure (lambda (call-env args)
                      (let ((fun-env (make-env call-env)))
                        (for-each (lambda (p a)
                                    (env-define! fun-env p a))
                                  params args)
                        (parameterize ((%current-env fun-env))
                          (eval-stmt body fun-env))))))
       (ts-fun closure)))
    (('fun name params body)
     (let ((closure (lambda (call-env args)
                      (let ((fun-env (make-env call-env)))
                        (for-each (lambda (p a)
                                    (env-define! fun-env p a))
                                  params args)
                        (parameterize ((%current-env fun-env))
                          (eval-stmt body fun-env))))))
       (env-define! env name (ts-fun closure))
       ts-null))
    (('array . elems)
     (ts-array (map (lambda (e) (eval-expr e env)) elems)))
    (('object . pairs)
     (ts-object (map (lambda (p)
                       (let ((k (car p))
                             (v (eval-expr (cadr p) env)))
                         (cons k v)))
                     pairs)))
    (('index obj idx)
     (let ((o (eval-expr obj env))
           (i (eval-expr idx env)))
       (cond
        ((eq? (ts-type o) 'array)
         (vector-ref (ts-val o) (ts-val i)))
     ((eq? (ts-type o) 'object)
      (let ((key (if (eq? (ts-type i) 'string)
                     (ts-val i)
                     (ts-val i))))
        (let ((found (assoc key (ts-val o) string=?)))
          (if found (cdr found) ts-null))))
        (default (error "Cannot index non-indexable type")))))
     (('member obj key)
      (let ((o (eval-expr obj env))
            (k key))
        (if (eq? (ts-type o) 'object)
            (let ((found (assoc k (ts-val o) string=?)))
              (if found
                  (cdr found)
                  (let ((native-method (lookup-native k o)))
                    (if native-method
                        (ts-native (lambda (args)
                                     (apply-native k o (map (lambda (a) (eval-expr a env)) args))))
                        ts-null))))
            (let ((native-method (lookup-native k o)))
              (if native-method
                  (ts-native (lambda (args)
                               (apply-native k o (map (lambda (a) (eval-expr a env)) args))))
                  (error "No such member: " k)))))
     (default
      (error "Unknown expression type: " expr)))))

;; --- Binary operations ---
(define (eval-binary op l r)
  (define (num-op proc)
    (if (and (eq? (ts-type l) 'number) (eq? (ts-type r) 'number))
        (ts-number (proc (ts-val l) (ts-val r)))
        (error "Numeric operation on non-numbers")))
  (match op
    ("+"
     (if (and (eq? (ts-type l) 'string) (eq? (ts-type r) 'string))
         (ts-string (string-append (ts-val l) (ts-val r)))
         (num-op +)))
    ("-"  (num-op -))
    ("*"  (num-op *))
    ("/"  (num-op /))
    ("%"  (num-op modulo))
    ("==" (ts-boolean (equal? (ts-val l) (ts-val r))))
    ("!=" (ts-boolean (not (equal? (ts-val l) (ts-val r)))))
    ("<"  (ts-boolean
            (and (eq? (ts-type l) 'number) (eq? (ts-type r) 'number)
                 (< (ts-val l) (ts-val r)))))
    (">"  (ts-boolean
            (and (eq? (ts-type l) 'number) (eq? (ts-type r) 'number)
                 (> (ts-val l) (ts-val r)))))
    ("<=" (ts-boolean
            (and (eq? (ts-type l) 'number) (eq? (ts-type r) 'number)
                 (<= (ts-val l) (ts-val r)))))
    (">=" (ts-boolean
            (and (eq? (ts-type l) 'number) (eq? (ts-type r) 'number)
                 (>= (ts-val l) (ts-val r)))))
    ("&&" (ts-boolean (and (ts-is-truthy? l) (ts-is-truthy? r))))
    ("||" (ts-boolean (or (ts-is-truthy? l) (ts-is-truthy? r))))
    (".."
     (let ((start (ts-val l)) (end (ts-val r)))
       (ts-array (map ts-number (iota (1+ (- end start)) start)))))
    (default (error "Unknown operator: " op))))

(define (eval-unary op v)
  (match op
    ("-" (ts-number (- (ts-val v))))
    ("!" (ts-boolean (not (ts-is-truthy? v))))
    ("not" (ts-boolean (not (ts-is-truthy? v))))
    (default (error "Unknown unary operator: " op))))

;; --- Function calls ---
(define (eval-call fn args env)
  (let ((type (ts-type fn)))
    (cond
     ((eq? type 'function)
      ((ts-val fn) env args))
     ((eq? type 'native)
      (apply (ts-val fn) args))
     (default (error "Cannot call non-function")))))

;; --- Main evaluation entry points ---

(define (evaluate ast)
  (let ((env (make-env #f)))
    (install-runtime env)
    (evaluate-prog ast env)))

(define (evaluate-string src)
  (evaluate (parse-from-string src)))

(define (evaluate-file filename)
  (evaluate (parse-file filename)))
